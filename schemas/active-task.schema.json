{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "active-task",
  "description": "AgentOS active-task.md - supports pointer and contract formats",
  "oneOf": [
    {
      "title": "Active Pointer Format",
      "required": ["type", "source_task", "activated_at"],
      "properties": {
        "type": { "type": "string", "const": "active-pointer" },
        "source_task": { "type": "string" },
        "activated_at": { "type": "string" },
        "transition": { "type": "string" }
      },
      "additionalProperties": true
    },
    {
      "title": "Task Contract Format",
      "required": ["task_id", "status"],
      "properties": {
        "task_id": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    }
  ]
}
