{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["lessons"],
  "properties": {
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source_incident",
          "tags",
          "trigger",
          "rule",
          "target_file",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^lesson-"
          },
          "source_incident": {
            "type": "string",
            "minLength": 1,
            "pattern": "^incident-"
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "trigger": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "target_file": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "accepted", "rejected", "implemented"]
          }
        }
      }
    }
  }
}
