{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["incident"],
  "properties": {
    "incident": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "date",
        "task_id",
        "severity",
        "category",
        "what_happened",
        "expected_behavior",
        "violated_rule",
        "root_cause",
        "fix",
        "rule_update_required",
        "target_file",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^task-"
        },
        "severity": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "category": {
          "type": "string",
          "enum": [
            "scope-creep",
            "missing-verification",
            "wrong-risk-level",
            "dangerous-command",
            "schema-violation",
            "commit-message",
            "context-selection",
            "other"
          ]
        },
        "what_happened": {
          "type": "string",
          "minLength": 1
        },
        "expected_behavior": {
          "type": "string",
          "minLength": 1
        },
        "violated_rule": {
          "type": "string",
          "minLength": 1
        },
        "root_cause": {
          "type": "string",
          "minLength": 1
        },
        "fix": {
          "type": "string",
          "minLength": 1
        },
        "rule_update_required": {
          "type": "boolean"
        },
        "target_file": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "rule_update_required": {
                "const": true
              }
            },
            "required": ["rule_update_required"]
          },
          "then": {
            "properties": {
              "target_file": {
                "type": "string",
                "minLength": 1,
                "not": {
                  "enum": ["TODO"]
                }
              }
            },
            "required": ["target_file"]
          }
        }
      ]
    }
  }
}
