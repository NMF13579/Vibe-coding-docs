{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-state.schema.json",
  "$comment": "This schema validates task state reports only. It does not execute transitions. It does not grant approval. It does not modify task files. It does not replace human review.",
  "title": "Task State Report",
  "description": "Read-only analysis result for AgentOS task state reporting.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "state",
    "evidence",
    "missing_evidence",
    "allowed_next_states",
    "blocked_reason"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0",
      "description": "Optional schema version for the task state report."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional UTC timestamp when the report was generated."
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "Task identifier, e.g. task-001."
    },
    "state": {
      "type": "string",
      "enum": [
        "idea",
        "brief_draft",
        "brief_approved",
        "review_ready",
        "review_blocked",
        "trace_written",
        "contract_drafted",
        "approved_for_execution",
        "active",
        "completed",
        "failed",
        "dropped",
        "state_conflict"
      ],
      "description": "Detected task state. state_conflict is a technical analysis result."
    },
    "evidence": {
      "type": "array",
      "description": "Structured evidence collected during state analysis.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "status", "note"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Evidence type or artifact category."
          },
          "path": {
            "type": "string",
            "description": "Relative path to the evidence file or directory."
          },
          "status": {
            "type": "string",
            "enum": ["present", "missing", "valid", "invalid", "conflicting", "planned"],
            "description": "Evidence status."
          },
          "note": {
            "type": "string",
            "description": "Human-readable evidence note."
          }
        }
      }
    },
    "missing_evidence": {
      "type": "array",
      "description": "List of expected evidence items that are not present.",
      "items": {
        "type": "string"
      }
    },
    "allowed_next_states": {
      "type": "array",
      "description": "Allowed next states from the detected state.",
      "items": {
        "type": "string",
        "enum": [
          "idea",
          "brief_draft",
          "brief_approved",
          "review_ready",
          "review_blocked",
          "trace_written",
          "contract_drafted",
          "approved_for_execution",
          "active",
          "completed",
          "failed",
          "dropped",
          "state_conflict"
        ]
      }
    },
    "blocked_reason": {
      "type": "string",
      "description": "Reason the current state blocks movement or is in conflict."
    },
    "warnings": {
      "type": "array",
      "description": "Optional non-fatal warnings from analysis.",
      "items": {
        "type": "string"
      }
    }
  }
}
