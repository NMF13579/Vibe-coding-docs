{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Brief Metadata",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "created_at",
    "source",
    "executable"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "const": "APPROVED"
    },
    "created_at": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "executable": {
      "type": "boolean",
      "const": false
    }
  },
  "additionalProperties": true
}
