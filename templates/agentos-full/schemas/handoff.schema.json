{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_summary"],
  "properties": {
    "session_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "current_goal",
        "decisions",
        "files_changed",
        "validation",
        "blockers",
        "next_allowed_actions"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^task-"
        },
        "current_goal": {
          "type": "string",
          "minLength": 1
        },
        "decisions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_changed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/validation_item"
          }
        },
        "blockers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_allowed_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "definitions": {
    "validation_item": {
      "type": "object",
      "required": ["command", "result", "proof"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": ["PASS", "FAIL", "SKIPPED", "TODO"]
        },
        "proof": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "result": {
                "enum": ["PASS", "FAIL", "SKIPPED"]
              }
            },
            "required": ["result"]
          },
          "then": {
            "properties": {
              "proof": {
                "type": "string",
                "minLength": 1,
                "not": {
                  "enum": ["TODO"]
                }
              }
            },
            "required": ["proof"]
          }
        }
      ]
    }
  }
}
